# Normalize text files to LF in the repo, CRLF allowed in working tree.
* text=auto

# Binary assets: never apply EOL normalization or text diffing (prevents corruption).
*.pdf  binary
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.webp binary
*.ico  binary
*.woff  binary
*.woff2 binary
*.ttf  binary
*.eot  binary
*.otf  binary
